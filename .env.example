# Run mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here

# Logging Configuration
# Set the log level for the application
# Valid values: debug, info, warning, error
# Default: info
# LOG_LEVEL=info

# Persist logs to a rotating file alongside stdout, so history survives a
# restart (the admin log buffer is in-memory only). On Fly, point this at the
# mounted volume or it is lost with the machine.
# LOG_FILE_PATH=/data/log/game_server.log
# LOG_FILE_LEVEL=info
# Rotation: bytes per file and how many to keep. Defaults to 10MB x 5, which
# bounds disk use at ~50MB.
# LOG_FILE_MAX_BYTES=10000000
# LOG_FILE_MAX_FILES=5

# Discord OAuth Configuration
# DISCORD_CLIENT_ID=your_discord_client_id_here
# DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Google OAuth Configuration
# GOOGLE_CLIENT_ID=google_client_id
# GOOGLE_CLIENT_SECRET=google_secret
# Native-app client id for verifying Google ID tokens from SDK sign-in.
# GOOGLE_WEB_CLIENT_ID=google_web_client_id
# Google Play server access token for validating in-app purchases.
# GOOGLE_PLAY_ACCESS_TOKEN=google_play_access_token

# Facebook OAuth Configuration
# FACEBOOK_CLIENT_ID=facebook_client_id
# FACEBOOK_CLIENT_SECRET=facebook_secret

# Apple OAuth Configuration
# APPLE_CLIENT_ID=client_id
# Separate web vs iOS audiences for verifying Apple ID tokens (Sign in with Apple).
# APPLE_WEB_CLIENT_ID=com.example.web
# APPLE_IOS_CLIENT_ID=com.example.ios
# APPLE_TEAM_ID=team_id
# APPLE_KEY_ID=key_id
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
# ...
# -----END PRIVATE KEY-----"

# PostgreSQL Database Configuration (optional)
# If not set, the app will use SQLite for development.
# NOTE: the database adapter is chosen at COMPILE time. After changing these,
# run: mix deps.clean game_server_core game_server_web --build
# and recompile (the app refuses to start on a stale build and says the same).
# (Docker deployments instead pick the adapter via the DATABASE_ADAPTER
# build arg — use the prebuilt "-postgres" image tag for Postgres.)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=game_server_dev

# Or use a single DATABASE_URL (takes precedence over individual POSTGRES_* vars)
# DATABASE_URL=ecto://postgres:postgres@localhost:5432/game_server_dev

# Database tuning / platform notes
#
# For platforms that use IPv6-only private networking (e.g. Fly.io), Ecto may need IPv6 enabled.
# ECTO_IPV6=true

# Steam OpenID Configuration
# STEAM_API_KEY=your_steam_api_key_here
# STEAM_APP_ID=your_steam_app_id_here

# Payments
# Global payment mode. Use sandbox while validating, production for real transactions.
# PAYMENTS_ENVIRONMENT=sandbox
#
# Stripe keys selected by PAYMENTS_ENVIRONMENT. Sandbox mode requires sk_test_...
# Production mode requires sk_live_...
# STRIPE_API_VERSION=2022-11-15
# STRIPE_SANDBOX_SECRET_KEY=sk_test_key
# STRIPE_SANDBOX_WEBHOOK_SECRET=whsec_sandbox_webhook_signing_secret
# STRIPE_PRODUCTION_SECRET_KEY=sk_live_key
# STRIPE_PRODUCTION_WEBHOOK_SECRET=whsec_production_webhook_signing_secret

# Google Play payments
# GOOGLE_PLAY_PACKAGE_NAME=com.example.game
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/google-play-service-account.json
# Alternative: inline JSON if your platform does not support secret files.
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Shared bearer token checked on Pub/Sub push webhook requests. REQUIRED in
# production: when unset, the RTDN webhook fails closed (401) in prod so it is
# never left unauthenticated. Dev/test accept requests without it.
# GOOGLE_PLAY_RTDN_TOKEN=shared_push_token
# Optional: acknowledge one-time purchases after validation.
# GOOGLE_PLAY_AUTO_ACKNOWLEDGE=true

# Apple App Store payments
# Signed StoreKit/App Store Server JWS payloads are verified against the pinned
# Apple Root CA - G3 shipped at apps/game_server_core/priv/certs/apple_root_ca_g3.pem.
# If that file is missing, Apple verification fails closed (no purchase is
# accepted). Refresh it from https://www.apple.com/certificateauthority/AppleRootCA-G3.cer.
# APPLE_BUNDLE_ID=com.example.game
# APPLE_ISSUER_ID=app_store_server_api_issuer_id
# APPLE_KEY_ID=app_store_server_api_key_id
# APPLE_PRIVATE_KEY_PATH=/run/secrets/AuthKey_ABC123DEFG.p8
# Alternative: inline .p8 content with escaped newlines.
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Steam MicroTxn payments
# STEAM_WEB_API_KEY=steam_web_api_key
# If unset, payments also fall back to STEAM_API_KEY from Steam OpenID config.
# STEAM_APP_ID=480

# When using SQLite in production (or on platforms with a mounted volume),
# set the path where the app should store the SQLite database file.
# Example local host-owned path: SQLITE_DATABASE_PATH=db/game_server_prod.db
# Example: SQLITE_DATABASE_PATH=/data/game_server_prod.db
# If not set, the app uses db/game_server_prod.db by default.
# SQLITE_DATABASE_PATH=/data/game_server_prod.db

# When deploying also set
# This secret is staged, but not deployed.
# Run fly deploy from a terminal.
# PHX_HOST=yourdomain.com

# Cache (Nebulex)
#
# Defaults:
# - CACHE_ENABLED=true
# - CACHE_MODE=single   (single instance: L1 local only)
# - CACHE_L2=partitioned (only used when CACHE_MODE=multi)
#
# Set to "false" to bypass caching entirely.
# CACHE_ENABLED=true
#
# Single instance (default): L1 local only
# CACHE_MODE=single
#
# Multi instance: L1 local + L2 (redis OR partitioned)
# CACHE_MODE=multi
# CACHE_L2=redis
#
# Redis L2 configuration (can use either CACHE_REDIS_URL or REDIS_URL)
# Local (host):
# CACHE_REDIS_URL=redis://localhost:6379/0
# When app runs inside docker-compose with a redis service named "redis":
# CACHE_REDIS_URL=redis://redis:6379/0
# Optional:
# CACHE_REDIS_POOL_SIZE=10
#
# Partitioned L2 configuration
# CACHE_L2=partitioned
# NOTE: partitioned L2 requires Erlang distribution + clustering.

# Clustering (required for multi-node partitioned cache)
#
# These are used by Elixir releases to enable Erlang distribution.
# All nodes must share RELEASE_COOKIE and each node must have a unique RELEASE_NODE.
# RELEASE_DISTRIBUTION=name
# RELEASE_NODE=myapp@fully-qualified-ip
# RELEASE_COOKIE=a_shared_secret_cookie
#
# DNS-based node discovery used by DNSCluster at boot.
# DNS_CLUSTER_QUERY=yourapp.internal
#
# Fly.io recommended settings
# DNS_CLUSTER_QUERY=${FLY_APP_NAME}.internal
# RELEASE_DISTRIBUTION=name
# RELEASE_NODE=${FLY_APP_NAME}-${FLY_IMAGE_REF##*-}@${FLY_PRIVATE_IP}
# RELEASE_COOKIE=... (set as a Fly secret)
# ERL_AFLAGS="-proto_dist inet6_tcp"
# ECTO_IPV6=true

# Rate Limiting (Hammer)
# Backend: "ets" (default, per-node counters) or "redis" (shared across all
# app instances — recommended when running more than one instance).
# With "redis", the URL comes from RATE_LIMIT_REDIS_URL, CACHE_REDIS_URL, or REDIS_URL.
# RATE_LIMIT_BACKEND=ets
# RATE_LIMIT_REDIS_URL=redis://localhost:6379
# General HTTP rate limit: max requests per window (default: 120 req/60s)
# RATE_LIMIT_HTTP_GENERAL_LIMIT=120
# RATE_LIMIT_HTTP_GENERAL_WINDOW=60000
# Auth HTTP endpoints (login/register): stricter limit (default: 10 req/60s)
# RATE_LIMIT_HTTP_AUTH_LIMIT=10
# RATE_LIMIT_HTTP_AUTH_WINDOW=60000
# WebSocket channel messages per user (default: 60 msg/10s)
# RATE_LIMIT_WS_LIMIT=60
# RATE_LIMIT_WS_WINDOW=10000
# WebRTC DataChannel messages per user (default: 300 msg/10s)
# RATE_LIMIT_WEBRTC_LIMIT=300
# RATE_LIMIT_WEBRTC_WINDOW=10000

# Realtime state updates: coalesce bursts, pushing only the latest state per
# object after this many ms. 0 (default) pushes immediately and only
# deduplicates. A small value trades that much latency for fewer messages.
# REALTIME_DEBOUNCE_MS=0

# Data retention: prune rows older than N days (0 or unset = keep forever).
# Runs every 6 hours. Purchases/entitlements are never pruned.
# RETENTION_CHAT_DAYS=90
# RETENTION_NOTIFICATIONS_DAYS=30
# RETENTION_PAYMENT_EVENTS_DAYS=180

# Lobby snapshots: durable per-run record of lobby state for debugging, browsable
# at /admin/lobby-snapshots. Off by default — snapshots hold user metadata and KV,
# so the retention window below is what bounds that exposure.
# LOBBY_SNAPSHOTS_ENABLED=true
# User-scoped KV keys to capture, comma-separated. Empty captures none.
# LOBBY_SNAPSHOTS_USER_KV_KEYS=
# RETENTION_LOBBY_SNAPSHOTS_DAYS=30
# Runs flagged anomalous (hook error, desync) keep a longer window.
# RETENTION_LOBBY_SNAPSHOTS_FLAGGED_DAYS=90

# Directory containing OTP hook plugins
GAME_SERVER_PLUGINS_DIR=modules/plugins
# Enable device authentication.
# Easy to get started locally. NOTE: when true, POST /api/v1/login/device
# creates an anonymous account for any device_id with no secret (rate-limited
# per IP). Use high-entropy device_ids and consider disabling in production if
# you don't need anonymous accounts.
DEVICE_AUTH_ENABLED=true

# Prometheus /metrics auth. When set, every non-loopback scrape — including
# private/Docker-internal IPs — must send `Authorization: Bearer <token>`.
# When unset, loopback and private IPs may scrape without a token (dev default).
# METRICS_AUTH_TOKEN=long_random_token

# Browser CORS allowlist (HTTP API is bearer-token auth). Defaults to "*" when
# unset. Set an explicit comma-separated origin list in production if browser
# clients call the API cross-origin and you want to restrict it.
# PHX_ALLOWED_ORIGINS=https://game.example.com,https://www.example.com
# Public listing APIs (default: enabled). Set to false to disable the
# unauthenticated browse/list endpoints so third parties can't scrape or
# clone your data. Each flag also gates the matching realtime list channel
# and the public browser page (/groups, /leaderboards, /achievements).
# LIST_USERS_ENABLED=false         disables GET /api/v1/users and /users/:id
# LIST_LOBBIES_ENABLED=false       disables GET /api/v1/lobbies and the "lobbies" channel
# LIST_GROUPS_ENABLED=false        disables GET /api/v1/groups, /groups/:id, /groups/:id/members, the "groups" channel and the /groups pages
# LIST_LEADERBOARDS_ENABLED=false  disables the public GET/resolve /api/v1/leaderboards* endpoints and the /leaderboards pages (authenticated /records/me stays)
# LIST_ACHIEVEMENTS_ENABLED=false  disables the public GET /api/v1/achievements* endpoints and the /achievements page (authenticated /achievements/me stays)
# LIST_MATCHMAKING_ENABLED=false   disables GET /api/v1/matchmaking/stats (own-ticket endpoints stay)
#
# OpenAPI spec + Swagger UI (default: enabled). The spec is a complete map of
# your API — recommended: disable in production unless you want public docs.
# OPENAPI_ENABLED=false
#
# Validation & anti-abuse limits (GameServer.Limits). Every limit can be
# overridden with LIMIT_<KEY>; values below are the defaults.
#
# Global
# LIMIT_MAX_METADATA_SIZE=16384        max metadata JSON bytes (users, lobbies, groups, chat, ...)
# LIMIT_MAX_PAGE_SIZE=100              max page_size accepted by list endpoints
#
# Users
# LIMIT_MAX_DISPLAY_NAME=80
# LIMIT_MAX_EMAIL=160
# LIMIT_MAX_PROFILE_URL=512
# LIMIT_MAX_DEVICE_ID=256
# Concurrent WebSocket connections per user (0 disables; per app instance).
# LIMIT_MAX_SOCKETS_PER_USER=20
#
# Groups
# LIMIT_MAX_GROUP_TITLE=80
# LIMIT_MAX_GROUP_DESCRIPTION=500
# LIMIT_MAX_GROUP_MEMBERS=10000
# LIMIT_MAX_GROUPS_PER_USER=50         groups a user may be a member of
# LIMIT_MAX_GROUPS_CREATED_PER_USER=20
# LIMIT_MAX_GROUP_PENDING_INVITES=100
#
# Lobbies
# LIMIT_MAX_LOBBY_TITLE=80
# LIMIT_MAX_LOBBY_USERS=128
# LIMIT_MAX_LOBBY_PASSWORD=128
#
# Parties
# LIMIT_MAX_PARTY_SIZE=32
# LIMIT_MAX_PARTY_PENDING_INVITES=20
#
# Chat
# LIMIT_MAX_CHAT_CONTENT=4096
# Messages one user may send per rolling 24h (0 disables; needs rate limiting
# enabled; counted per app instance with the default ETS backend).
# LIMIT_MAX_CHAT_MESSAGES_PER_DAY=5000
#
# Notifications
# LIMIT_MAX_NOTIFICATION_TITLE=255
# LIMIT_MAX_NOTIFICATION_CONTENT=10000
# LIMIT_MAX_NOTIFICATIONS_PER_USER=500
#
# Friends
# LIMIT_MAX_FRIENDS_PER_USER=500
# LIMIT_MAX_PENDING_FRIEND_REQUESTS=100
#
# Hooks (plugin RPC)
# LIMIT_MAX_HOOK_ARGS_SIZE=65536
# LIMIT_MAX_HOOK_ARGS_COUNT=32
#
# Key-value store
# LIMIT_MAX_KV_KEY=512
# LIMIT_MAX_KV_VALUE_SIZE=65536
# LIMIT_MAX_KV_ENTRIES_PER_USER=1000
#
# Leaderboards
# LIMIT_MAX_LEADERBOARD_TITLE=255
# LIMIT_MAX_LEADERBOARD_DESCRIPTION=1000
# LIMIT_MAX_LEADERBOARD_SLUG=100
#
# Matchmaking
# LIMIT_MAX_MATCHMAKING_PLAYERS=64
# LIMIT_MAX_MATCHMAKING_PARAMS_SIZE=2048
# LIMIT_MATCHMAKING_TIMEOUT_MS=30000
# LIMIT_MATCHMAKING_TICK_MS=3000
# LIMIT_MATCHMAKING_OFFLINE_GRACE_MS=300000
# Require admin activation for new accounts (beta mode).
# When true, new users cannot log in until an admin activates them.
# REQUIRE_ACCOUNT_ACTIVATION=false
# Minimum password length enforced at registration/change (default 8).
# MIN_PASSWORD_LENGTH=8
# Public Grafana URL linked from the admin dashboard, if you host one.
# GRAFANA_PUBLIC_URL=https://grafana.example.com
# Set theme (only locale-suffixed files are loaded, e.g. .en.json, .es.json)
# THEME_CONFIG=modules/example_config.json
# Set email
# SMTP_USERNAME="resend"
# SMTP_PASSWORD="your_resend_api_key"
# SMTP_RELAY="smtp.resend.com"
# SMTP_PORT=465
# SMTP_SSL=false
# SMTP_TLS=false
# Recommended: configure the sender name and email so providers accept mail
# (make sure the domain is verified with your provider to avoid errors)
# SMTP_FROM_NAME="Game Server"
# SMTP_FROM_EMAIL="no-reply@example.com"
# If secrets don't deploy to fly, do:
# fly secrets sync
# fly secrets deploy

# When testing in localhost, set
# MIX_ENV=dev
