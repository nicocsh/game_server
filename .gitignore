# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
game_server-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json
/priv/static/**/*.gz
/priv/static/**/*-????????????????????????????????.*

# Umbrella layout: ignore generated/digested static assets in the web app
/apps/game_server_web/priv/static/
!/apps/game_server_web/priv/static/game/
!/apps/game_server_web/priv/static/fonts/
!/apps/game_server_web/priv/static/images/
!/apps/game_server_web/priv/static/favicon.ico
!/apps/game_server_web/priv/static/robots.txt
/apps/game_server_web/apps/game_server_web/priv/static/

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/
/apps/game_server_web/assets/node_modules/

.DS_Store
.elixir_ls/

# Environment variables
.env

redis/
/db/
clients/javascript/
clients/node_modules/
clients/godot/
clients/addons/
godot_addons/addons/gamend/
stress/results/
clients/gamend/
sdk_tools/doc/

# Translation CSV exports (generated by mix gettext.export_csv)
/translations/*.csv
/scripts/
apps/game_server_web/apps/game_server_web/priv/static/cache_manifest.json
apps/game_server_web/apps/game_server_web/priv/static/favicon-0793a89617220e350e9e66698d2d4fa8.ico
apps/game_server_web/apps/game_server_web/priv/static/favicon.ico
*.pyc
translations/google_sheets_translations.py
translations/README.md
translations/GOOGLE_SHEETS_README.md
translations/credentials.json
translations/token.json

# GeoIP MMDB databases (large binary files, download separately)
data/*.mmdb
data/COPYRIGHT.txt
data/LICENSE.txt
apps/game_server_core/_build/
apps/game_server_core/deps/
apps/game_server_web/_build/
apps/game_server_web/deps/
apps/game_server_web/priv/db/

# Rotating log files (dev: log/dev.log, docker compose: logs/).
/log/
/logs/
